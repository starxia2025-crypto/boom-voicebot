NODE_ENV=development
PORT=4000
APP_URL=http://localhost:5173
CORS_ORIGIN=http://localhost:5173
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/boom_asistente?schema=public
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.5
OPENAI_REASONING_EFFORT=medium
OPENAI_TTS_MODEL=gpt-4o-mini-tts
OPENAI_TTS_VOICE=marin
DEFAULT_BRANCH=Sucursal Centro
VOICE_STT_PROVIDER=faster_whisper
VOICE_TTS_PROVIDER=openai
VOICE_SERVICE_URL=http://localhost:8000
VOICE_WAKEWORD_ENABLED=false
VOICE_WAKEWORD_PHRASE=Oye Boom
WHISPER_HOTWORDS=boom, muebles boom, stock, precio, sucursal, sofa, sillon, colchon, mesa
MAX_CSV_FILE_SIZE_BYTES=5242880
MAX_CHAT_QUESTION_LENGTH=500
ENABLE_TTS=true
